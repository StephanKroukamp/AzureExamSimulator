<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Azure Exam Simulator</title>
    <link rel="stylesheet" href="css/app.css" />
    <script>
        (function() {
            var t = localStorage.getItem('theme');
            if (t) document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
</head>

<body>
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <script src="_framework/blazor.web.js"></script>
    <script>
        window.__registerKeyHandler = function(dotNetRef) {
            window.__keyDotNetRef = dotNetRef;
            window.__keyHandler = function(e) {
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
                if (e.key === ' ') e.preventDefault();
                dotNetRef.invokeMethodAsync('OnKeyPress', e.key);
            };
            document.addEventListener('keydown', window.__keyHandler);
        };
        window.__printWithTitle = function(fileName) {
            var originalTitle = document.title;
            document.title = fileName;
            return new Promise(function(resolve) {
                setTimeout(function() {
                    window.print();
                    document.title = originalTitle;
                    resolve();
                }, 100);
            });
        };
        window.__unregisterKeyHandler = function() {
            if (window.__keyHandler) {
                document.removeEventListener('keydown', window.__keyHandler);
                window.__keyHandler = null;
            }
            window.__keyDotNetRef = null;
        };
    </script>
</body>

</html>
